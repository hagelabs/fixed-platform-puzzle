{
  "name": "fixed-platform-puzzle",
  "version": "0.1.0",
  "description": "Grid-based puzzle game for Poki and CrazyGames",
  "private": true,
  "scripts": {
    "dev": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "analyze": "webpack --config webpack.config.js --mode production --env analyze",
    "size": "du -sh dist/ && ls -lh dist/",
    "validate-levels": "tsx scripts/validate-levels.ts",
    "bake-levels": "tsx scripts/bake-levels.ts",
    "package:poki": "npm run build && cd dist && zip -r ../submission/poki-build.zip . && cd ..",
    "package:crazygames": "npm run build && cd dist && zip -r ../submission/crazygames-build.zip . && cd ..",
    "package:itch": "tsx scripts/package-itch.ts"
  },
  "keywords": [
    "phaser",
    "puzzle",
    "game",
    "poki",
    "crazygames"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "phaser": "^4.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "compression-webpack-plugin": "^12.0.0",
    "html-webpack-plugin": "^5.6.7",
    "terser-webpack-plugin": "^5.5.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
